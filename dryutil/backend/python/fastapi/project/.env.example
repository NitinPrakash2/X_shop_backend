# Database Configuration
DB_HOST='localhost'
DB_PORT='5432'
DB_USERNAME='usr1mn'
DB_PASSWORD='your_secure_database_password_here'
DB_DATABASE='dryutil'
DATABASE_URL='postgresql+asyncpg://usr1mn:password@localhost:5432/dryutil'

# Application
NODE_ENV='dev'
PORT='8000'

# RSA Keys (Generate using: https://cryptotools.net/rsagen)
# Encode with base64: https://www.base64encode.org/
# NEVER commit actual keys to repository
RSA_PUBLIC_KEY_BASE_64='your_base64_encoded_public_key_here'
RSA_PRIVATE_KEY_BASE_64='your_base64_encoded_private_key_here'

# Cookie Signing Secret (Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_FOR_COOKIES_SIGN='your_secure_random_secret_here'

# X (Twitter) OAuth 2.0
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
X_CLIENT_ID='your_x_client_id_here'
X_CLIENT_SECRET='your_x_client_secret_here'
X_CALLBACK_URL='http://localhost:8000/client-public/api/i/ona/xshop?action=x_oauth_callback'

# External Product API
PRODUCT_API_URL='http://localhost:8000/client/api/i/ona/product_dir'
PRODUCT_API_TOKEN='your_jwt_product_api_token_here'

# Security Notes:
# - Use environment variables or secrets vault in production (AWS Secrets Manager, HashiCorp Vault)
# - Never commit .env with actual secrets to version control
# - Rotate secrets regularly
# - Use strong, unique passwords for database and API tokens
# - Keep .env file with placeholder values only for documentation
