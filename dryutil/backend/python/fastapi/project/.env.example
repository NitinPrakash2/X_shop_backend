# ─── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name
# Use %24 to escape $ in password inside the URL
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@localhost:5432/your_db_name

# ─── App ────────────────────────────────────────────────────
NODE_ENV=dev
PORT=8000

# ─── JWT (RS256) ─────────────────────────────────────────────
# Generate RSA key pair: https://cryptotools.net/rsagen
# Then base64-encode each key: https://www.base64encode.org/
RSA_PUBLIC_KEY_BASE_64=<base64_encoded_rsa_public_key>
RSA_PRIVATE_KEY_BASE_64=<base64_encoded_rsa_private_key>
SECRET_FOR_COOKIES_SIGN=<random_secret_string>

# ─── X (Twitter) OAuth 2.0 ──────────────────────────────────
# Create app at: https://developer.twitter.com/en/portal/dashboard
# Required scopes: tweet.read tweet.write users.read offline.access
X_CLIENT_ID=<your_x_oauth2_client_id>
X_CLIENT_SECRET=<your_x_oauth2_client_secret>
X_CALLBACK_URL=http://localhost:8000/client-public/api/i/ona/xshop?action=x_oauth_callback

# ─── External Product API ───────────────────────────────────
PRODUCT_API_URL=http://localhost:8000/client/api/i/ona/product_dir
# Bearer token for the product API (party_1 or party_2 JWT)
PRODUCT_API_TOKEN=<bearer_token_for_product_api>
